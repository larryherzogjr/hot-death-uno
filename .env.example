# Copy to `.env` (same dir as docker-compose.yml). The `.env` file is gitignored.

# Shared passcode to gate game creation. Empty / unset = open server.
HDU_PASSCODE=

# Seconds between AI moves (how slowly the AI plays). Default 1.2.
HDU_AI_DELAY=1.2

# --- Google OAuth sign-in (optional) --------------------------------------
# Leave the client id/secret blank to disable sign-in entirely (manual names).
# Create an OAuth client in Google Cloud Console (APIs & Services > Credentials,
# "OAuth client ID", type "Web application") and set the authorized redirect URI
# to <HDU_BASE_URL>/auth/callback, e.g. https://hdu.ospdy.com/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public base URL — used to build the OAuth callback behind the nginx proxy.
HDU_BASE_URL=https://hdu.ospdy.com

# Stable random secret that signs the login session cookie. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If unset, a new one is made each restart (everyone gets logged out on deploy).
HDU_SESSION_SECRET=

# Require Google sign-in to create or join a game. Empty/0 = sign-in optional.
HDU_REQUIRE_LOGIN=

# Optional allow-list: comma-separated emails permitted to sign in. Empty = any.
HDU_ALLOWED_EMAILS=
